# ----------------------------------------------------------------------------
# Mẫu biến môi trường. Sao chép file này thành `.env.local` rồi điền giá trị thật.
#   cp .env.example .env.local
# (.env.local đã được .gitignore bỏ qua nên KHÔNG bị đẩy lên GitHub)
# ----------------------------------------------------------------------------

# MongoDB Atlas — chuỗi kết nối (dùng dạng mongodb:// chuẩn nếu mạng chặn SRV)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# JWT secret để ký cookie phiên đăng nhập (đặt chuỗi ngẫu nhiên, dài)
JWT_SECRET=change-this-to-a-long-random-string

# Cloudinary — lưu ảnh quán do admin tải lên
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Hai biến NEXT_PUBLIC_* dưới đây dùng cho UPLOAD TRỰC TIẾP từ trình duyệt lên
# Cloudinary (né giới hạn 4.5MB body của Vercel). Phải cấu hình cả ở Vercel.
#   - CLOUD_NAME: cùng giá trị với CLOUDINARY_CLOUD_NAME ở trên.
#   - UPLOAD_PRESET: preset đặt ở chế độ Unsigned trên Cloudinary.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=ml_default

# Google Maps JavaScript API key (tùy chọn).
# Bỏ trống -> bản đồ tự dùng OpenStreetMap (miễn phí, không cần key).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Map ID cho Advanced Marker của Google Maps (tùy chọn, mặc định dùng DEMO_MAP_ID)
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Tài khoản admin tạo tự động khi DB chưa có admin nào (seed).
# Bỏ trống email/password -> KHÔNG tự tạo admin (dùng scripts/make-admin.mjs thay thế).
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin
